# ──────────────────────────────────────────────────────────────
# .env.example — Umgebungsvariablen für den aom-sys-scanner-rag Stack
#
# Kopieren und anpassen:
#   cp workflows/.env.example ~/aom-sys-scanner-rag/.env
#   $EDITOR ~/aom-sys-scanner-rag/.env
#
# Alle drei Skripte lesen diese Datei:
#   setup-scanner-rag.sh  · buchhaltungsbot.sh  · cloudflare-tunnel-helper.sh
#
# HRFR-v2 · sys-Domain · Stand 2025
# ──────────────────────────────────────────────────────────────

# ── Projekt ──────────────────────────────────────────────────
PROJECT_DIR="$HOME/aom-sys-scanner-rag"
LOG_FILE="/var/log/aom-scanner-setup.log"

# ── Paperless-ngx ────────────────────────────────────────────
# (setup-scanner-rag.sh · buchhaltungsbot.sh)
PAPERLESS_URL="http://localhost:8000"
PAPERLESS_DB_PASS="sicheres-passwort"
PAPERLESS_TOKEN="dein-paperless-api-token"

# ── Ollama ────────────────────────────────────────────────────
# (setup-scanner-rag.sh · buchhaltungsbot.sh · rag-indexer.py)
# Basic Auth wird aus der URL geparst: http://user:passwort@host:port
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:3b"
OLLAMA_EMBED_MODEL="nomic-embed-text"

# ── ChromaDB ──────────────────────────────────────────────────
# (rag-indexer.py · buchhaltungsbot.sh — ChromaDB-Variante)
CHROMA_URL="http://localhost:8100"

# ── PostgreSQL/pgvector ───────────────────────────────────────
# (rag-indexer-pg.py · buchhaltungsbot.sh — wird bevorzugt wenn vorhanden)
# Nutzt die bereits vorhandene Paperless-PostgreSQL-Instanz mit pgvector-Erweiterung.
PG_HOST="localhost"
PG_PORT="5432"
PG_DB="paperless"
PG_USER="paperless"
PG_PASS="sicheres-passwort"
PG_TABLE="aom_rag_documents"

# ── Cloudflare ────────────────────────────────────────────────
# (setup-scanner-rag.sh · cloudflare-tunnel-helper.sh · buchhaltungsbot.sh)
CF_TUNNEL_TOKEN="dein-cloudflare-tunnel-token"
CF_TUNNEL_NAME="aom-cachyos-tunnel"
CF_DOMAIN="meinedomain.de"
CF_CONFIG_DIR="$HOME/.cloudflared"

# ── Buchhaltungsbot ───────────────────────────────────────────
# (buchhaltungsbot.sh)
BOT_HEALTH_PORT="8077"
CHECK_INTERVAL="300"
CF_CHECK_INTERVAL="60"
HAWK_EYE_INTERVAL="600"
MAX_CF_RETRIES="3"
PID_FILE="/tmp/aom-buchhaltungsbot.pid"
